Use the prettier code formatting defined in @.prettierrc for all .jsx, .tsx, .js and .ts files: 
{
  "singleQuote": true,
  "jsxSingleQuote": true,
  "semi": false,
  "tabWidth": 2,
  "bracketSpacing": true,
  "jsxBracketSameLine": false,
  "arrowParens": "always",
  "endOfLine":"auto",
  "printWidth":120
}
